+"""Test-harness helper: probe whether the bsddb database backend is loadable
+on the running platform.
+
+The legacy-bsddb import tests in :mod:`gramps.plugins.test.imports_test` must
+skip — not fail — when neither :mod:`berkeleydb` (the maintained successor)
+nor :mod:`bsddb3` (deprecated since Python 3.6) is installed.  The plugin's
+own loader at ``gramps/plugins/db/bsddb/bsddb.py`` (lines 32-35) tries the
+same pair, in the same order, and silently falls back; this helper asks the
+same question without exercising the loader (and therefore without raising
+the loader's ``can't load database backend: 'bsddb'`` exception that the
+test is meant to skip on).
+"""
+
+
+def bsddb_backend_available():
+    """Return ``True`` iff either ``berkeleydb`` or ``bsddb3`` is importable.
+
+    Mirrors the probe order at ``gramps/plugins/db/bsddb/bsddb.py:32-35`` so
+    the test harness's notion of "bsddb is available" matches the loader's.
+    """
+    try:
+        import berkeleydb  # noqa: F401
+
+        return True
+    except ImportError:
+        pass
+    try:
+        import bsddb3  # noqa: F401
+
+        return True
+    except ImportError:
+        pass
+    return False
