+"""Unittest for uimanager.py.
+
+Regression test for bug 13636: closing the main window before a queued
+``page_changer`` idle callback fires must not crash ``UIManager.update_menu``.
+During a page change ``ViewManager`` schedules ``page_changer`` via
+``GLib.idle_add`` (``gramps/gui/viewmanager.py:1061-1066``), which calls
+``UIManager.update_menu()``.  If the window is torn down first, the previous
+toolbar is already detached, so ``toolbar.get_parent()`` returns ``None`` and
+the unguarded ``toolbar_parent.remove(toolbar)`` raised
+``AttributeError: 'NoneType' object has no attribute 'remove'``.
+
+The test runs headless: ``gi.repository`` is stubbed in ``sys.modules`` before
+importing the module under test, so no GTK typelib and no display are required.
+"""
+
+import sys
+import unittest
+from unittest import mock
+
+# Stub out gi / gi.repository so importing gramps.gui.uimanager needs neither a
+# GTK typelib nor a display.  Must happen before the module under test is
+# imported.  uimanager.py does ``from gi.repository import GLib, Gio, Gtk``.
+_GI = mock.MagicMock()
+sys.modules.setdefault("gi", _GI)
+sys.modules.setdefault("gi.repository", _GI.repository)
+
+from gramps.gui import uimanager
+
+
+class TestUpdateMenuDetachedToolbar(unittest.TestCase):
+    """update_menu must survive the window-teardown race of bug 13636."""
+
+    def _make_manager(self, parent):
+        """Build a UIManager whose *previous* builder yields a toolbar whose
+        get_parent() returns ``parent``.
+
+        ``parent=None`` reproduces the shutdown race: the previous toolbar has
+        already been detached from its container.
+        """
+        prev_toolbar = mock.MagicMock(name="previous_toolbar")
+        prev_toolbar.get_parent.return_value = parent
+
+        prev_builder = mock.MagicMock(name="previous_builder")
+        prev_builder.get_object.return_value = prev_toolbar
+
+        app = mock.MagicMock(name="app")
+        mgr = uimanager.UIManager(app, "<interface></interface>")
+        # Simulate that init has already happened: a previous builder exists.
+        mgr.builder = prev_builder
+        return mgr, prev_toolbar
+
+    def test_update_menu_detached_toolbar_does_not_raise(self):
+        """get_parent() is None (window torn down) -> return cleanly, no crash."""
+        mgr, _prev_toolbar = self._make_manager(parent=None)
+        try:
+            result = mgr.update_menu(init=False)
+        except AttributeError as err:
+            self.fail(
+                "update_menu(init=False) raised AttributeError when the previous "
+                "toolbar was already detached (bug 13636): %s" % err
+            )
+        # The toolbar-rebuild path is skipped rather than crashing.
+        self.assertIsNone(result)
+
+    def test_update_menu_attached_toolbar_rebuilds(self):
+        """Sanity: with a real parent the rebuild path still runs (no guard hit)."""
+        parent = mock.MagicMock(name="toolbar_parent")
+        mgr, prev_toolbar = self._make_manager(parent=parent)
+        mgr.update_menu(init=False)
+        # The previous toolbar is detached from its parent as before the fix.
+        parent.remove.assert_called_once_with(prev_toolbar)
+
+
+if __name__ == "__main__":
+    unittest.main()
