+"""
+Regression test for issue 46: GraphView/graphview.py raised a bare Exception
+at *module import* when the GraphViz ``dot`` binary (or GooCanvas) was
+unavailable (graphview.py:120-122 / :111-113). The module-level raise
+duplicates the registration-layer gate (requires_exe=["dot"] /
+requires_gi=[("GooCanvas", ...)]) that Gramps' plugin manager already owns,
+and breaks every direct importer -- including this addon's own test
+collection, which crashes during import on a host lacking ``dot``.
+
+The module must instead import without a side-effecting failure when a
+declared dependency is absent; whether the plugin loads stays the sole
+responsibility of the requires_* gate at registration time.
+
+This test imports the *production* ``GraphView.graphview`` module with the
+``dot`` binary simulated absent (PATH emptied) and asserts the import
+completes without raising. To avoid crashing the headless test collector,
+the gi/Gtk-bound production module is imported *inside* the test method,
+never at this test module's top level.
+"""
+
+import os
+import sys
+import unittest
+
+# Pin Gtk 3.0 before anything pulls in gramps.gui (which require_version("Gtk",
+# "3.0") at its own import). This mirrors the sibling GraphView test
+# (test_graphview_dot_handles.py) and is lightweight: `import gi` plus a version
+# pin loads no widgets and needs no display. The Gtk-bound production module is
+# imported only inside the test method, never at this module's load time, so the
+# headless collector never executes a GUI import during collection.
+import gi
+
+gi.require_version("Gtk", "3.0")
+
+
+class GraphViewImportTest(unittest.TestCase):
+    """The plugin module must import even when its external deps are absent."""
+
+    def _reimport_graphview(self):
+        """Force a fresh top-level execution of GraphView.graphview."""
+        # Drop any cached copy so the module body (the lines that read
+        # PATH via search_for("dot")) runs again under the current env.
+        sys.modules.pop("GraphView.graphview", None)
+        import GraphView.graphview as graphview  # noqa: F401 -- import is the assertion
+
+        return graphview
+
+    def test_module_imports_without_dot_on_path(self):
+        # Simulate the GraphViz `dot` binary being unavailable. search_for()
+        # (gramps.gen.utils.file) returns 0 when no PATH entry holds `dot`,
+        # so _DOT_FOUND is falsy -- pre-fix this triggers the module-level
+        # `raise Exception("GraphViz ... required")` during import.
+        orig_path = os.environ.get("PATH", "")
+        saved = sys.modules.pop("GraphView.graphview", None)
+        try:
+            os.environ["PATH"] = ""
+            # Pre-fix: this import raises Exception -> test errors (red).
+            # Post-fix: the import completes cleanly (green).
+            graphview = self._reimport_graphview()
+            # The DOT generator class must be reachable on the imported module,
+            # proving the production path imported, not just "didn't raise".
+            self.assertTrue(hasattr(graphview, "DotSvgGenerator"))
+            from GraphView.graphview import DotSvgGenerator  # noqa: F401
+
+            self.assertIs(graphview.DotSvgGenerator, DotSvgGenerator)
+        finally:
+            os.environ["PATH"] = orig_path
+            # Restore the original cached module so sibling tests are unaffected.
+            if saved is not None:
+                sys.modules["GraphView.graphview"] = saved
+            else:
+                sys.modules.pop("GraphView.graphview", None)
+
+
+if __name__ == "__main__":
+    unittest.main()
