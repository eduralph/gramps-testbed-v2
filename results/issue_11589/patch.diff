+    def __plugins_sharing_dir(self, pdata):
+        """
+        Return the registered plugins, other than *pdata*, whose files live
+        in the same directory (``fpath``).
+
+        Used to decide whether uninstalling *pdata* may remove its whole
+        directory or must remove only its own files: a multi-plugin pack such
+        as FilterRules ships every rule in one shared directory (bug 11589).
+        """
+        shared = {}
+        for ptype in PTYPE_STR:
+            for other in self._preg.type_plugins(ptype):
+                if other.id != pdata.id and other.fpath == pdata.fpath:
+                    shared[other.id] = other
+        return list(shared.values())
+
+    def __remove_plugin_files(self, pdata, siblings):
+        """
+        Delete only the files belonging to *pdata* -- its implementation
+        ``.py`` (``pdata.fname``) and the matching ``.gpr.py`` registration
+        file -- leaving the shared directory and everything else in it intact.
+
+        Skips removal when a sibling plugin is registered from the same ``.py``
+        file (several rules can be registered from one ``.py`` / ``.gpr.py``
+        pair), so a still-registered sibling never loses its files.
+        """
+        if pdata.fname in {other.fname for other in siblings}:
+            return
+        base = os.path.splitext(pdata.fname)[0]
+        for fname in (base + ".gpr.py", pdata.fname):
+            target = os.path.join(pdata.fpath, fname)
+            if os.path.isfile(target):
+                os.remove(target)
+
     def __uninstall(self, pid, path):
         """Uninstall the plugin"""
         pdata = self._pmgr.get_plugin(pid)
+        siblings = self.__plugins_sharing_dir(pdata)
         try:
-            if os.path.islink(pdata.fpath):  # linux link
+            if siblings:
+                # The directory is shared by other registered plugins (e.g. the
+                # multi-rule FilterRules pack). Removing the whole directory
+                # would destroy those siblings and any unrelated user content,
+                # so remove only this plugin's own files (bug 11589).
+                self.__remove_plugin_files(pdata, siblings)
+            elif os.path.islink(pdata.fpath):  # linux link
                 os.unlink(pdata.fpath)
             elif os.stat(pdata.fpath).st_ino != os.lstat(pdata.fpath).st_ino:
