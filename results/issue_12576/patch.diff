+class ConvertCalendarUnknownDayTest(BaseDateTest):
+    """
+    Regression for bug 12576: converting an approximate date (unknown day,
+    day == 0) between calendars must preserve the unknown day rather than
+    fabricating a precise one from the SDN round-trip.
+    """
+
+    def test_unknown_day_preserved_gregorian_to_persian(self):
+        d = Date()
+        d.set_yr_mon_day(2022, 3, 0)
+        d.convert_calendar(Date.CAL_PERSIAN)
+        self.assertEqual(d.get_day(), 0)
+
+    def test_unknown_day_preserved_persian_to_gregorian(self):
+        d = Date()
+        d.set_calendar(Date.CAL_PERSIAN)
+        d.set_yr_mon_day(1400, 12, 0)
+        d.convert_calendar(Date.CAL_GREGORIAN)
+        self.assertEqual(d.get_day(), 0)
+
+    def test_known_day_still_converts(self):
+        # The original (now-fixed) exact case must keep round-tripping: a
+        # precise source day stays precise after conversion.
+        d = Date()
+        d.set_yr_mon_day(2022, 2, 19)
+        d.convert_calendar(Date.CAL_PERSIAN)
+        self.assertEqual(d.get_ymd(), (1400, 11, 30))
+
+
 if __name__ == "__main__":
     unittest.main()
