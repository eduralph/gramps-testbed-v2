+"""Unittest for viewmanager.py.
+
+Regression test for bug 8796: hiding **every** view plugin in the Plugin
+Manager makes Gramps crash at startup with
+``IndexError: list assignment index out of range``.
+
+With no view plugins available, ``ViewManager.get_available_views()`` returns
+``[]``, so ``views_to_show([])`` yields ``(0, 0, [])``
+(``gramps/gui/viewmanager.py`` ``views_to_show``).  ``init_interface`` then sets
+``self.current_views = []`` and calls ``goto_page(0, 0)``, whose
+``self.current_views[cat_num] = view_num`` indexes the empty list and raises.
+
+This test drives the **production** functions on the real
+``gramps.gui.viewmanager`` module -- the same ``views_to_show`` /
+``ViewManager.goto_page`` that ``init_interface`` chains
+(``viewmanager.py`` ``init_interface`` -> ``goto_page``) -- not a copy.
+
+The C4-verify runner is HEADLESS (no display / D-Bus / AT-SPI), and
+``viewmanager.py`` does ``from gi.repository import Gtk`` plus a tree of
+``gramps.gui.*`` widget imports.  Importing it for real would need a GTK
+typelib and a display and would crash the runner.  So ``gi`` and the
+``gramps.gui`` submodules ``viewmanager`` imports are stubbed in ``sys.modules``
+*before* the import: the module body still runs and defines the **real**
+``ViewManager`` class and ``views_to_show`` function, which is what we exercise.
+"""
+
+import sys
+import types
+import unittest
+from unittest import mock
+
+
+def _install_import_stubs():
+    """Make ``gramps.gui.viewmanager`` importable on a headless runner.
+
+    Returns the imported module.  Stubs ``gi`` and the ``gramps.gui`` widget
+    submodules so the module body executes without a GTK typelib or a display,
+    while leaving ``ViewManager`` / ``views_to_show`` -- both defined *in*
+    viewmanager.py -- as the real production code under test.
+    """
+
+    class _Base:
+        """Real-type stand-in for base classes viewmanager subclasses."""
+
+        def __init__(self, *args, **kwargs):
+            pass
+
+    # gi / gi.repository: a MagicMock satisfies ``from gi.repository import Gtk``.
+    _gi = mock.MagicMock()
+    sys.modules.setdefault("gi", _gi)
+    sys.modules.setdefault("gi.repository", _gi.repository)
+
+    # gramps.gui widget submodules viewmanager imports -- only their *names*
+    # are needed at import time (they are dereferenced at runtime, inside
+    # methods we do not call), so plain MagicMocks suffice.
+    for name in (
+        "gramps.gui.user",
+        "gramps.gui.plug",
+        "gramps.gui.plug.report",
+        "gramps.gui.utils",
+        "gramps.gui.pluginmanager",
+        "gramps.gui.displaystate",
+        "gramps.gui.dialog",
+        "gramps.gui.widgets",
+        "gramps.gui.undohistory",
+        "gramps.gui.dbloader",
+        "gramps.gui.display",
+        "gramps.gui.configure",
+        "gramps.gui.aboutdialog",
+        "gramps.gui.navigator",
+        "gramps.gui.views.tags",
+        "gramps.gui.uimanager",
+        "gramps.gui.editors",
+        "gramps.gui.fs.manager",
+        "gramps.gui.fs.session",
+        "gramps.gui.fs.tools_window",
+    ):
+        sys.modules.setdefault(name, mock.MagicMock())
+
+    # Base classes must be real types so the ``class ViewManager(CLIManager)``
+    # and ``class QuickBackup(ManagedWindow)`` statements succeed.
+    sys.modules.setdefault("gramps.cli.grampscli", mock.MagicMock(CLIManager=_Base))
+    sys.modules.setdefault(
+        "gramps.gui.managedwindow", mock.MagicMock(ManagedWindow=_Base)
+    )
+
+    from gramps.gui import viewmanager
+
+    return viewmanager
+
+
+viewmanager = _install_import_stubs()
+
+
+def _empty_view_manager():
+    """A ViewManager in the all-views-hidden startup state.
+
+    Built via ``__new__`` to bypass the heavy GTK ``__init__``; the attributes
+    set here are exactly those ``init_interface`` establishes just before it
+    calls ``goto_page`` (``self.views`` / ``self.current_views`` from
+    ``views_to_show()``, plus ``self.active_page``).
+    """
+    vman = viewmanager.ViewManager.__new__(viewmanager.ViewManager)
+    vman.views = []
+    vman.current_views = []
+    vman.page_lookup = {}
+    vman.active_page = None
+    return vman
+
+
+class TestEmptyViewsStartup(unittest.TestCase):
+    """The navigation path must be total over zero available views (bug 8796)."""
+
+    def test_views_to_show_empty(self):
+        """No views -> default selection is empty, never raising."""
+        self.assertEqual(viewmanager.views_to_show([], use_last=False), (0, 0, []))
+
+    def test_goto_page_empty_views_does_not_raise(self):
+        """goto_page on the empty-view startup state must not crash.
+
+        This is the production path ``init_interface`` takes:
+        ``defaults = views_to_show(self.views)`` -> ``self.current_views =
+        defaults[2]`` (== ``[]``) -> ``self.goto_page(defaults[0],
+        defaults[1])``.  Pre-fix this raises
+        ``IndexError: list assignment index out of range``; post-fix it
+        resolves to a no-active-page state.
+        """
+        vman = _empty_view_manager()
+        current_cat, current_view, default_cat_views = viewmanager.views_to_show(
+            vman.views, use_last=False
+        )
+        vman.current_views = default_cat_views
+        try:
+            result = vman.goto_page(current_cat, current_view)
+        except IndexError as err:
+            self.fail(
+                "goto_page() raised IndexError on the empty-view startup state "
+                "(bug 8796): %s" % err
+            )
+        # No page could be shown -> no active page, no crash.
+        self.assertIsNone(result)
+        self.assertIsNone(vman.active_page)
+
+    def test_config_view_no_active_page_does_not_raise(self):
+        """config_view must not dereference a None active_page (bug 8796 cascade)."""
+        vman = _empty_view_manager()
+        try:
+            vman.config_view()
+        except AttributeError as err:
+            self.fail(
+                "config_view() raised AttributeError with no active page "
+                "(bug 8796): %s" % err
+            )
+
+
+if __name__ == "__main__":
+    unittest.main()
