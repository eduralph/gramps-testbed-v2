+# along with this program; if not, write to the
+# Free Software Foundation, Inc., 51 Franklin Street, Fifth Floor, Boston, MA 02110-1301 USA.
+#
+
+"""
+Regression test for Mantis issue 8653 -- the Deep Connections Gramplet must not
+route a connection path back through the Home (start) person, i.e. the start
+person must appear only as the implicit search root, never as an intermediate
+relationship step in a produced path (the reporter's
+"... / sibling of another person / sibling of main person" chain).
+
+The gramplet module imports Gtk at load time, so the connection-search logic was
+extracted into the GUI-free ``connection_search`` module (no ``gi`` /
+``gramps.gui`` import).  This test exercises that module directly with a tiny
+in-memory database, so it runs under a plain ``python3 -m unittest`` with no
+display / D-Bus / AT-SPI.
+"""
+
+import importlib.util
+import os
+import unittest
+
+# Load the GUI-free search module by file path (no gi import is triggered).
+_IMPL_PATH = os.path.join(
+    os.path.dirname(os.path.dirname(os.path.abspath(__file__))),
+    "connection_search.py",
+)
+_spec = importlib.util.spec_from_file_location("connection_search", _IMPL_PATH)
+connection_search = importlib.util.module_from_spec(_spec)
+_spec.loader.exec_module(connection_search)
+
+
+# ---------------------------------------------------------------------------
+# Minimal in-memory stand-ins for the Gramps person/family/db objects, exposing
+# only the accessors connection_search.get_relatives uses.
+# ---------------------------------------------------------------------------
+class _ChildRef:
+    def __init__(self, ref):
+        self.ref = ref
+
+
+class _Person:
+    def __init__(self, handle, families=(), parent_families=()):
+        self.handle = handle
+        self._families = list(families)
+        self._parent_families = list(parent_families)
+
+    def get_family_handle_list(self):
+        return self._families
+
+    def get_parent_family_handle_list(self):
+        return self._parent_families
+
+    def get_person_ref_list(self):
+        return []
+
+    def get_note_list(self):
+        return []
+
+
+class _Family:
+    def __init__(self, handle, father=None, mother=None, children=()):
+        self.handle = handle
+        self._father = father
+        self._mother = mother
+        self._children = list(children)
+
+    def get_child_ref_list(self):
+        return [_ChildRef(c) for c in self._children]
+
+    def get_father_handle(self):
+        return self._father
+
+    def get_mother_handle(self):
+        return self._mother
+
+    def get_note_list(self):
+        return []
+
+
+class _DB:
+    def __init__(self, people, families):
+        self._people = people
+        self._families = families
+
+    def get_person_from_handle(self, handle):
+        return self._people.get(handle)
+
+    def get_family_from_handle(self, handle):
+        return self._families.get(handle)
+
+    def get_note_from_handle(self, handle):  # pragma: no cover - no notes here
+        return None
+
+
+def _nibling_db():
+    """
+    Home person D and sibling S are children of family Fp (parents P1/P2).
+    S has their own family Fs with spouse W and child A.  So the active person A
+    connects to the Home person D as "child of D's sibling S" -- a two-hop path
+    that, before the fix, was rendered with D as an intermediate
+    "sibling of <Home>" step.
+    """
+    families = {
+        "Fp": _Family("Fp", father="P1", mother="P2", children=["D", "S"]),
+        "Fs": _Family("Fs", father="S", mother="W", children=["A"]),
+    }
+    people = {
+        "D": _Person("D", parent_families=["Fp"]),
+        "S": _Person("S", families=["Fs"], parent_families=["Fp"]),
+        "A": _Person("A", parent_families=["Fs"]),
+        "W": _Person("W", families=["Fs"]),
+        "P1": _Person("P1", families=["Fp"]),
+        "P2": _Person("P2", families=["Fp"]),
+    }
+    return _DB(people, families)
+
+
+class TestStartPersonNotIntermediate(unittest.TestCase):
+    """The Home (start) person must never be an intermediate path step (8653)."""
+
+    def _first_path_steps(self, db, home, active):
+        paths = connection_search.search_connections(db, home, active)
+        self.assertTrue(paths, "expected a connection path from %s to %s" % (home, active))
+        return connection_search.path_steps(paths[0])
+
+    def test_home_not_an_intermediate_step_on_multi_hop_path(self):
+        """A two-hop connection must not list the Home person mid-path."""
+        db = _nibling_db()
+        steps = self._first_path_steps(db, "D", "A")
+
+        non_root = [s for s in steps if s[0] != connection_search.SELF]
+        intermediate_handles = [handle for (relation, handle) in non_root]
+
+        # Guard against a vacuous pass: the connection must genuinely route
+        # through the intermediate relative S (active A is "child of S"), i.e.
+        # this is the multi-hop case the bug needs -- not a direct relative.
+        self.assertIn(
+            "S",
+            intermediate_handles,
+            "scenario does not route through the intermediate S; path=%r" % (steps,),
+        )
+
+        # The bug: D (Home) appears as a non-root "sibling of <Home>" step.
+        self.assertNotIn(
+            "D",
+            intermediate_handles,
+            "Home person re-entered as an intermediate step; path=%r" % (steps,),
+        )
+
+    def test_home_present_only_as_root(self):
+        """The Home person is still recorded -- exactly once, as the root."""
+        db = _nibling_db()
+        steps = self._first_path_steps(db, "D", "A")
+
+        root = steps[-1]
+        self.assertEqual(root, (connection_search.SELF, "D"))
+        self.assertEqual(
+            [handle for (relation, handle) in steps].count("D"),
+            1,
+            "Home person should appear exactly once (as the root); path=%r" % (steps,),
+        )
+
+    def test_direct_relative_still_found_without_home_mid_path(self):
+        """A direct sibling of Home still connects, with Home only as root."""
+        db = _nibling_db()
+        steps = self._first_path_steps(db, "D", "S")  # S is Home's sibling
+        intermediate_handles = [
+            handle for (relation, handle) in steps if relation != connection_search.SELF
+        ]
+        self.assertNotIn("D", intermediate_handles, "path=%r" % (steps,))
+
+
+if __name__ == "__main__":
+    unittest.main()
