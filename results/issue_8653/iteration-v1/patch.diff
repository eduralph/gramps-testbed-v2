+"""
+GUI-free breadth-first connection search for the Deep Connections Gramplet.
+
+The relation-gathering and path-search logic used to live entangled with the
+Gtk UI inside :class:`DeepConnectionsGramplet` (``self.append_text``,
+``self.link``, generator ``yield`` points).  It is extracted here so the
+algorithm can be exercised without importing ``gi`` / ``gramps.gui``; the
+gramplet now delegates to :func:`get_relatives` and so re-uses the exact code
+the tests cover.
+
+Path representation (unchanged from the gramplet)::
+
+    (more_path, (relation_text, anchor_handle, [parent_handle, ...]))
+
+The chain terminates in the *root* node ``(None, ("self", start_handle, []))``,
+where ``start_handle`` is the Home / start person.
+
+Issue 8653 -- the Home (start) person is the implicit origin of the search and
+must appear *only* as that root, never re-entered as an intermediate
+relationship step in a produced path (the reporter's "... / sibling of main
+person" chain).  :func:`get_relatives` enforces that with two rules applied on
+top of the original relation-gathering:
+
+  * the start person is dropped if it turns up as a relative of another node,
+    so it can never be re-entered as an intermediate node; and
+  * relatives **of** the start person are linked straight to the root node
+    instead of through a redundant ``(relation, start_handle)`` step, so the
+    start person is recorded as the root and nowhere else.
+"""
+
+SELF = "self"  # relation marker for the root (start) node; never translated
+
+
+def _identity(text):
+    """Default no-op translation, so the module needs no gramps import."""
+    return text
+
+
+def get_links_from_notes(db, obj, path, relation, person_handle, _=_identity):
+    """
+    Get anyone mentioned in any note attached to ``obj``.
+    """
+    retval = []
+    for note_handle in obj.get_note_list():
+        note = db.get_note_from_handle(note_handle)
+        if note:
+            for link in note.get_links():
+                if link[0] == "gramps" and link[1] == "Person":
+                    relation = _("mentioned in note")
+                    if link[2] == "handle":
+                        retval += [(link[3], (path, (relation, person_handle)))]
+    return retval
+
+
+def get_relatives(db, person_handle, path, _=_identity, start_handle=None):
+    """
+    Return ``[(relative_handle, relative_path), ...]`` for ``person_handle``.
+
+    The body below is the original gramplet relation-gathering, verbatim; the
+    issue-8653 start-person exclusion is applied as an explicit post-process so
+    the original behaviour stays reviewable and ``start_handle=None`` reproduces
+    it exactly.
+    """
+    person = db.get_person_from_handle(person_handle)
+    if person is None:
+        return []
+    retval = []
+    family_list = person.get_family_handle_list()
+    for family_handle in family_list:
+        family = db.get_family_from_handle(family_handle)
+        if family:
+            children = family.get_child_ref_list()
+            husband = family.get_father_handle()
+            wife = family.get_mother_handle()
+            retval.extend(
+                (child_ref.ref, (path, (_("child"), person_handle, husband, wife)))
+                for child_ref in children
+            )
+            if husband and husband != person_handle:
+                retval += [(husband, (path, (_("husband"), person_handle)))]
+            if wife and wife != person_handle:
+                retval += [(wife, (path, (_("wife"), person_handle)))]
+            retval += get_links_from_notes(
+                db, family, path, _("Note on Family"), person_handle, _
+            )
+
+    parent_family_list = person.get_parent_family_handle_list()
+    for family_handle in parent_family_list:
+        family = db.get_family_from_handle(family_handle)
+        if family:
+            children = family.get_child_ref_list()
+            husband = family.get_father_handle()
+            wife = family.get_mother_handle()
+            retval.extend(
+                (child_ref.ref, (path, (_("sibling"), person_handle, husband, wife)))
+                for child_ref in children
+                if child_ref.ref != person_handle
+            )
+            if husband and husband != person_handle:
+                retval += [(husband, (path, (_("father"), person_handle, wife)))]
+            if wife and wife != person_handle:
+                retval += [(wife, (path, (_("mother"), person_handle, husband)))]
+            retval += get_links_from_notes(
+                db, family, path, _("Note on Parent Family"), person_handle, _
+            )
+
+    assoc_list = person.get_person_ref_list()
+    for assoc in assoc_list:
+        relation = _("%s (association)") % assoc.get_relation()
+        assoc_handle = assoc.get_reference_handle()
+        retval += [(assoc_handle, (path, (relation, person_handle)))]
+
+    retval += get_links_from_notes(
+        db, person, path, _("Note on Person"), person_handle, _
+    )
+
+    # --- issue 8653: keep the Home (start) person out of the path body ---
+    if start_handle is not None:
+        # The start person must never be re-entered as an intermediate node.
+        retval = [(handle, rel_path) for (handle, rel_path) in retval if handle != start_handle]
+        if person_handle == start_handle:
+            # Relatives of the start person connect to the implicit root
+            # (``path`` is the root node here), not through a redundant
+            # "(relation, start)" step that would print the Home person mid-path.
+            retval = [(handle, path) for (handle, _rel_path) in retval]
+    return retval
+
+
+def search_connections(db, default_handle, active_handle, _=_identity, max_paths=1):
+    """
+    Breadth-first search for connection paths from the Home (``default_handle``)
+    person to ``active_handle``.
+
+    Returns a list of paths (the linked-list structure documented above), at
+    most ``max_paths`` of them.  This mirrors the BFS run by
+    ``DeepConnectionsGramplet.main`` (minus the Gtk progress / pause plumbing)
+    and shares the issue-8653 fix through :func:`get_relatives`.
+    """
+    cache = set()
+    queue = [(default_handle, (None, (SELF, default_handle, [])))]
+    found = []
+    while queue:
+        current_handle, current_path = queue.pop(0)
+        if current_handle == active_handle:
+            found.append(current_path)
+            if default_handle == active_handle or len(found) >= max_paths:
+                break
+            continue
+        if current_handle in cache:
+            continue
+        cache.add(current_handle)
+        for person_handle, rel_path in get_relatives(
+            db, current_handle, current_path, _, start_handle=default_handle
+        ):
+            if person_handle is not None:
+                queue.append((person_handle, rel_path))
+    return found
+
+
+def path_steps(path):
+    """
+    Flatten a path into ``[(relation_text, anchor_handle), ...]`` ordered from
+    the outermost step down to the root ``(SELF, start_handle)`` node.
+    """
+    steps = []
+    node = path
+    while node is not None:
+        steps.append((node[1][0], node[1][1]))
+        node = node[0]
+    return steps
