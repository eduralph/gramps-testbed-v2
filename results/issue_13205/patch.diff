+def citation_handles_of_source(db, source_handle):
+    """
+    Return the handles of the Citation objects that reference a source.
+
+    Collects only the *Citation* backlinks of ``source_handle``.  A source can
+    legitimately be backlinked by objects other than citations (for example a
+    Note that carries a source/citation reference); such non-Citation backlinks
+    are skipped rather than treated as citations.
+
+    This guards callers -- notably the Merge Citations tool -- against assuming
+    that every backlink of a source is a Citation, which otherwise aborts the
+    whole operation with a ``MergeError`` (bug 13205).
+
+    :param db: the database to search.
+    :param source_handle: handle of the source whose citations are wanted.
+    :returns: list of Citation handles referencing the source.
+    :rtype: list
+    """
+    (citation_handles,) = get_source_referents(source_handle, db)
+    return citation_handles
+
