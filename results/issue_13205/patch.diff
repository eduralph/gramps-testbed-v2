+
+"""
+Regression test for bug 13205: Merge Citations must not abort when a source
+is referenced by a non-Citation object (e.g. a Note that carries a
+source/citation reference).
+
+This imports ONLY the GUI-free helper ``citation_handles_of_source`` from
+``gramps.gen.utils.db`` -- it never imports the Gtk-bound
+``gramps.plugins.tool.mergecitations`` tool module, so it runs under the
+headless verify harness without pulling in the GUI stack.
+"""
+
+import unittest
+
+from gramps.gen.utils.db import citation_handles_of_source
+
+
+class _FakeDb:
+    """
+    Minimal stand-in for a Gramps database exposing only the method the helper
+    needs.  ``find_backlink_handles`` returns the raw ``(class_name, handle)``
+    backlinks unfiltered, so the helper itself is responsible for keeping only
+    the Citation backlinks -- exactly the behaviour bug 13205 is about.
+    """
+
+    def __init__(self, backlinks):
+        self._backlinks = backlinks
+
+    def find_backlink_handles(self, handle, include_classes=None):
+        for class_name, ref_handle in self._backlinks:
+            if include_classes is None or class_name in include_classes:
+                yield (class_name, ref_handle)
+
+
+class MergeCitationsBacklinkTest(unittest.TestCase):
+    """Cover the source -> citation-handles collection used by Merge Citations."""
+
+    def test_non_citation_backlink_is_skipped(self):
+        """
+        A source backlinked by a Note (non-Citation) plus two Citations must
+        yield only the Citation handles, without raising.  Before the fix the
+        Merge Citations loop raised ``MergeError`` on the Note backlink.
+        """
+        db = _FakeDb(
+            [
+                ("Citation", "citation_0001"),
+                ("Note", "note_0001"),
+                ("Citation", "citation_0002"),
+            ]
+        )
+
+        # Must not raise -- the non-Citation (Note) backlink is skipped.
+        handles = citation_handles_of_source(db, "source_0001")
+
+        self.assertEqual(
+            sorted(handles), ["citation_0001", "citation_0002"]
+        )
+        self.assertNotIn("note_0001", handles)
+
+    def test_source_with_only_citations(self):
+        """A source backlinked solely by Citations returns all of them."""
+        db = _FakeDb(
+            [("Citation", "citation_0001"), ("Citation", "citation_0002")]
+        )
+        self.assertEqual(
+            sorted(citation_handles_of_source(db, "source_0001")),
+            ["citation_0001", "citation_0002"],
+        )
+
+    def test_source_with_no_citations(self):
+        """A source backlinked only by a non-Citation yields an empty list."""
+        db = _FakeDb([("Note", "note_0001")])
+        self.assertEqual(citation_handles_of_source(db, "source_0001"), [])
+
+
+if __name__ == "__main__":
+    unittest.main()
